{
  "mcpServers": {
    "cloudup": {
      "command": "${CLAUDE_PLUGIN_ROOT}/scripts/cloudup-server.sh",
      "env": {
        "CLOUDUP_WALLET_KEY": "${CLOUDUP_WALLET_KEY}",
        "CLOUDUP_MAX_USD": "${CLOUDUP_MAX_USD:-0.10}",
        "CLOUDUP_MCP_URL": "${CLOUDUP_MCP_URL:-https://api.stage-cloudup.com/mcp/public}"
      }
    }
  }
}
