{
  "mcpServers": {
    "cloudup": {
      "type": "stdio",
      "command": "bash",
      "args": [
        "${CLAUDE_PLUGIN_ROOT}/scripts/cloudup-server.sh"
      ],
      "env": {
        "CLOUDUP_MCP_URL": "${CLOUDUP_MCP_URL:-https://api.stage-cloudup.com/mcp/public}",
        "CLOUDUP_MAX_USD": "${CLOUDUP_MAX_USD:-0.20}"
      }
    }
  }
}
